# vault/example.secrets.enc.yaml.sample
# =============================================================================
# ILLUSTRATIVE ONLY. sops and age were not installed in the environment that
# populated this repo, so this is NOT real sops ciphertext — every ENC[...]
# block and the sops: footer below are placeholder text, not decryptable.
#
# It exists purely to show the SHAPE of the real artifact. Once you have sops
# + age installed, generate the real thing with:
#
#   sops -e vault/example.secrets.yaml > vault/example.secrets.enc.yaml
#
# ...and commit THAT file (not this .sample) as the real encrypted vault
# entry. The real output replaces every `data:`/`iv:`/`tag:` placeholder with
# genuine AES-256-GCM ciphertext, and the `sops.age[].enc` field with a real
# age-wrapped data key.
# =============================================================================
services:
    demo_api:
        api_key: ENC[AES256_GCM,data:PLACEHOLDER-NOT-REAL-CIPHERTEXT==,iv:PLACEHOLDER-IV=,tag:PLACEHOLDER-TAG=,type:str]
    demo_db:
        password: ENC[AES256_GCM,data:PLACEHOLDER-NOT-REAL-CIPHERTEXT==,iv:PLACEHOLDER-IV=,tag:PLACEHOLDER-TAG=,type:str]
    demo_signing:
        cert_p12_base64: ENC[AES256_GCM,data:PLACEHOLDER-NOT-REAL-CIPHERTEXT==,iv:PLACEHOLDER-IV=,tag:PLACEHOLDER-TAG=,type:str]
sops:
    age:
        - recipient: age1PLACEHOLDER0000000000000000000000000000000000000000000000
          enc: |
              PLACEHOLDER — not a real age-wrapped data key
    lastmodified: "2026-07-13T00:00:00Z"
    mac: ENC[AES256_GCM,data:PLACEHOLDER==,iv:PLACEHOLDER=,tag:PLACEHOLDER=,type:str]
    pgp: []
    encrypted_regex: ^(data|api_key|password|cert_p12_base64)$
    version: 3.9.4
